# Environment Variables Template - FRONTEND
# Copy this to .env for local development
# cp .env.example .env

# ====================
# Application
# ====================
NODE_ENV=development
VITE_APP_NAME=JobLoom
VITE_APP_VERSION=1.0.0

# ====================
# API Configuration
# ====================
# Update this with your backend API URL
VITE_API_URL=http://localhost:5000/api
VITE_API_TIMEOUT=30000

# ====================
# Mapbox Integration
# ====================
# Get your token from https://www.mapbox.com/
# VITE_MAPBOX_TOKEN=your_mapbox_token_here

# ====================
# Feature Flags
# ====================
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true
VITE_ENABLE_MOCK_API=false

# ====================
# Calendly (OAuth - Client ID only, for OAuth redirect)
# ====================
# Get from https://developer.calendly.com/
VITE_CALENDLY_CLIENT_ID=your_calendly_client_id

# ====================
# Development
# ====================
# Enable hot reload in Docker
CHOKIDAR_USEPOLLING=true

# ====================
# Production (Set during build)
# ====================
# VITE_API_URL=https://api.jobloom.com/api
# VITE_MAPBOX_TOKEN=pk.your_production_token
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_DEBUG=false

# ====================
# Staging
# ====================
# VITE_API_URL=https://api-staging.jobloom.com/api
# VITE_MAPBOX_TOKEN=pk.your_staging_token
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_DEBUG=true

VITE_GOOGLE_MAPS_API_KEY = google_maps_api_key_here

