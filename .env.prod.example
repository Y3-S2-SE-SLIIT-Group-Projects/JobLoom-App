NODE_ENV=production

# Optional: pull and run this registry image instead of local build
# Example: ghcr.io/<org-or-user>/jobloom-app:v1.0.0
APP_IMAGE=jobloom-app:latest

# Frontend build-time API endpoint (used by Vite during docker build)
VITE_API_URL=http://localhost:3008/api

# Google Maps API key (baked into the production bundle)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Jitsi domain baked into the production bundle (hostname only)
VITE_JITSI_DOMAIN=meet.jit.si

# Container and port mapping
APP_CONTAINER_NAME=jobloom-prod
APP_HOST_PORT=8080

# Healthcheck tuning
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=3s
HEALTHCHECK_RETRIES=3
HEALTHCHECK_START_PERIOD=10s

# Runtime behavior
RESTART_POLICY=always

# Resource constraints
LIMIT_CPUS=1
LIMIT_MEMORY=512M
RESERVATION_CPUS=0.5
RESERVATION_MEMORY=256M
